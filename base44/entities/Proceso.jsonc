{
  "name": "Proceso",
  "type": "object",
  "properties": {
    "nombre": {
      "type": "string",
      "title": "Nombre del proceso"
    },
    "activo": {
      "type": "boolean",
      "title": "Activo",
      "default": true
    }
  },
  "required": [
    "nombre"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "data.espacioId": "{{user.active_space_id}}"
            },
            {
              "data.activo": true
            }
          ]
        },
        {
          "data.espacioId": {
            "$exists": false
          },
          "data.activo": true
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}