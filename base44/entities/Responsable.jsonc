{
  "name": "Responsable",
  "type": "object",
  "properties": {
    "espacioId": {
      "type": "string",
      "title": "ID del espacio de equipo"
    },
    "nombre": {
      "type": "string",
      "title": "Nombre"
    },
    "rol_funcion": {
      "type": "string",
      "title": "Rol o funci\u00f3n"
    },
    "email": {
      "type": "string",
      "title": "Correo electr\u00f3nico"
    },
    "activo": {
      "type": "boolean",
      "title": "Activo",
      "default": true
    }
  },
  "required": [
    "nombre"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.espacioId": {
            "$in": "{{user.data.memberSpaceIds}}"
          }
        },
        {
          "data.activo": true
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}