{
  "name": "Responsable",
  "type": "object",
  "properties": {
    "nombre": {
      "type": "string",
      "title": "Nombre"
    },
    "email": {
      "type": "string",
      "title": "Correo electrónico"
    },
    "correoNormalizado": {
      "type": "string",
      "title": "Correo normalizado (búsqueda)"
    },
    "rol_funcion": {
      "type": "string",
      "title": "Rol o función"
    },
    "usuarioId": {
      "type": "string",
      "title": "ID de usuario vinculado"
    },
    "usuarioEmail": {
      "type": "string",
      "title": "Email del usuario vinculado"
    },
    "activo": {
      "type": "boolean",
      "title": "Activo",
      "default": true
    },
    "fechaCreacion": {
      "type": "string",
      "format": "date-time",
      "title": "Fecha de creación"
    },
    "ultimaActualizacion": {
      "type": "string",
      "format": "date-time",
      "title": "Última actualización"
    }
  },
  "required": [
    "nombre"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.activo": true
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}