{
  "name": "Pedido",
  "type": "object",
  "properties": {
    "espacioId": {
      "type": "string",
      "title": "ID del espacio de equipo"
    },
    "titulo": {
      "type": "string",
      "title": "Título del pedido"
    },
    "descripcion": {
      "type": "string",
      "title": "Descripción"
    },
    "solicitante": {
      "type": "string",
      "title": "Solicitante"
    },
    "sede": {
      "type": "string",
      "title": "Sede",
      "enum": [
        "Clínica Delgado",
        "Clínica Bellavista",
        "OncoCenter",
        "Cantella",
        "Medicina Nuclear",
        "Asistencia Médica",
        "Corporativo",
        "Otro"
      ]
    },
    "proceso": {
      "type": "string",
      "title": "Proceso",
      "enum": [
        "Selección",
        "Bienestar",
        "SST",
        "Clima",
        "Liderazgo",
        "ACI",
        "Onboarding",
        "Comunicaciones internas",
        "Legal laboral",
        "Compensaciones",
        "Gestión de talento",
        "Otros"
      ]
    },
    "prioridad": {
      "type": "string",
      "title": "Prioridad",
      "enum": [
        "Alta",
        "Media",
        "Baja"
      ]
    },
    "fecha_requerida": {
      "type": "string",
      "format": "date",
      "title": "Fecha requerida"
    },
    "responsable": {
      "type": "string",
      "title": "Responsable asignado"
    },
    "estado": {
      "type": "string",
      "title": "Estado",
      "enum": [
        "Nuevo",
        "Por priorizar",
        "Asignado",
        "En curso",
        "Bloqueado",
        "En revisión",
        "Cerrado"
      ],
      "default": "Nuevo"
    },
    "proxima_accion": {
      "type": "string",
      "title": "Próxima acción"
    },
    "motivo_bloqueo": {
      "type": "string",
      "title": "Motivo de bloqueo"
    },
    "comentarios_avance": {
      "type": "string",
      "title": "Comentarios de avance"
    },
    "link_evidencia": {
      "type": "string",
      "title": "Link o evidencia relacionada"
    },
    "resultado_final": {
      "type": "string",
      "title": "Resultado final"
    },
    "comentario_cierre": {
      "type": "string",
      "title": "Comentario de cierre"
    },
    "fecha_cierre_real": {
      "type": "string",
      "format": "date",
      "title": "Fecha real de cierre"
    },
    "calendar_event_id": {
      "type": "string",
      "title": "ID evento Google Calendar"
    },
    "archivado": {
      "type": "boolean",
      "title": "Archivado",
      "default": false
    },
    "fecha_archivado": {
      "type": "string",
      "format": "date",
      "title": "Fecha de archivo"
    },
    "archivado_por": {
      "type": "string",
      "title": "Archivado por"
    },
    "motivo_archivo": {
      "type": "string",
      "title": "Motivo de archivo"
    },
    "confidencial": {
      "type": "boolean",
      "title": "Confidencial",
      "default": false
    },
    "marcado_confidencial_por": {
      "type": "string",
      "title": "Marcado confidencial por"
    },
    "fecha_marcado_confidencial": {
      "type": "string",
      "format": "date",
      "title": "Fecha marcado confidencial"
    },
    "motivo_confidencial": {
      "type": "string",
      "title": "Motivo de confidencialidad"
    }
  },
  "required": [
    "titulo",
    "solicitante",
    "proceso",
    "prioridad"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.espacioId": "{{user.active_space_id}}"
        }
      ]
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "data.espacioId": "{{user.active_space_id}}"
            },
            {
              "$or": [
                {
                  "data.confidencial": false
                },
                {
                  "created_by": "{{user.email}}"
                },
                {
                  "data.solicitante": "{{user.full_name}}"
                },
                {
                  "data.responsable": "{{user.full_name}}"
                }
              ]
            }
          ]
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}